{
  "name": "clauduck",
  "version": "0.1.1",
  "description": "Analyze your Claude Code usage with DuckDB",
  "type": "module",
  "bin": {
    "clauduck": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "lint": "tsc --noEmit",
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "claude",
    "claude-code",
    "analytics",
    "duckdb",
    "cli",
    "tui"
  ],
  "author": "duyet",
  "license": "MIT",
  "dependencies": {
    "@duckdb/node-api": "^1.5.1-r.1",
    "ink": "^5.2.0",
    "ink-text-input": "^6.0.0",
    "@inkjs/ui": "^2.0.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
